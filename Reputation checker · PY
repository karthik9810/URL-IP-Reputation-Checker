console = Console()

# ── Known spam/phishing indicators ───────────────────────────────────────────
SPAM_TLDS        = {'.tk','.ml','.ga','.cf','.pw','.xyz','.top','.click','.loan',
                    '.bid','.win','.gq','.cc','.su','.icu','.monster','.buzz','.cyou'}
BRAND_KEYWORDS   = ['paypal','apple','google','microsoft','amazon','netflix','bank',
                    'secure','login','verify','update','account','confirm','support',
                    'webscr','signin','ebay','facebook','instagram','icloud','chase',
                    'wellsfargo','citi','hsbc','dhl','fedex','usps','prize','winner',
                    'claim','reward','free','lucky','congratulations']
SAFE_DOMAINS     = {'google.com','youtube.com','facebook.com','instagram.com','twitter.com',
                    'x.com','github.com','microsoft.com','apple.com','amazon.com',
                    'wikipedia.org','reddit.com','linkedin.com','netflix.com','stackoverflow.com',
                    'cloudflare.com','dropbox.com','paypal.com','ebay.com','zoom.us'}
TOR_OCTETS       = {185, 194, 193, 176, 199, 198, 197}

BANNER = r"""
 ____  ____   __   __  __     ___  _  _  ____  ___  __ _  ____  ____ 
/ ___)(  _ \ / _\ (  \/  )   / __)/ )( \(  __)/ __)(  / )( ___)(  _ \
\___ \ ) __//    \ )    (   ( (__ ) __ ( ) _)( (__  )  (  )__)  )   /
(____/(__)  \_/\_/(_/\/\_)   \___)\_)(_/(____)\___)(__)_)(____)(__\_)
"""

# ── Helpers ───────────────────────────────────────────────────────────────────
def is_ip(t):
    return bool(re.match(r'^(\d{1,3}\.){3}\d{1,3}$', t.strip())) and \
           all(0 <= int(x) <= 255 for x in t.strip().split('.'))

def extract_domain(url):
    try:
        if not url.startswith(('http://', 'https://')):
            url = 'http://' + url
        return urllib.parse.urlparse(url).hostname or url
    except:
        return url

def get_base_domain(domain):
    parts = domain.split('.')
    return '.'.join(parts[-2:]) if len(parts) >= 2 else domain

def dns_resolve(domain):
    try:
        return socket.gethostbyname(domain), True
    except:
        return "Cannot resolve", False

# ── Spam Analysis ─────────────────────────────────────────────────────────────
def check_target(target):
    target = target.strip()
    checks = []       # (emoji, name, value, status)  status: ok/warn/bad
    spam_score = 0

    if is_ip(target):
        parts = list(map(int, target.split('.')))
        private  = parts[0]==10 or (parts[0]==172 and 16<=parts[1]<=31) or (parts[0]==192 and parts[1]==168)
        loopback = parts[0]==127
        tor_like = parts[0] in TOR_OCTETS

        checks.append(("🌐", "Type",            "IPv4 Address",                      "ok"))
        checks.append(("🏠", "Private IP",      "Yes – internal network" if private else "No – public IP",   "warn" if private else "ok"))
        checks.append(("🔁", "Loopback",        "Yes (127.x.x.x)" if loopback else "No",                    "warn" if loopback else "ok"))
        checks.append(("🧅", "Tor/VPN Range",   "⚠️  Possibly anonymous" if tor_like else "Normal range",    "bad"  if tor_like else "ok"))
        checks.append(("📍", "Geolocation",     "Use ipinfo.io to verify",           "warn"))

        if tor_like:    spam_score += 40
        if private:     spam_score += 10

    else:
        domain = extract_domain(target.lower())
        base   = get_base_domain(domain)
        lower  = target.lower()

        is_https     = lower.startswith('https://')
        spam_tld     = any(domain.endswith(t) for t in SPAM_TLDS)
        ip_in_url    = bool(re.search(r'\d+\.\d+\.\d+\.\d+', domain))
        long_sub     = any(len(p) > 25 for p in domain.split('.')[:-2])
        brand_spoof  = any(b in lower for b in BRAND_KEYWORDS) and base not in SAFE_DOMAINS
        excess_dash  = domain.count('-') > 3
        num_sub      = any(p.isdigit() for p in domain.split('.')[:-2])
        deep_path    = lower.count('/') > 6
        is_trusted   = base in SAFE_DOMAINS
        resolved_ip, resolved_ok = dns_resolve(domain)
        url_len_sus  = len(target) > 120

        checks.append(("🔒", "HTTPS",            "Secure ✅" if is_https else "Insecure ⚠️",                       "ok"   if is_https    else "warn"))
        checks.append(("🌐", "Domain",           domain,                                                           "ok"))
        checks.append(("🛡️", "Trusted Domain",  "Yes – well-known site ✅" if is_trusted else "Not in safe list",  "ok"   if is_trusted  else "warn"))
        checks.append(("📛", "Suspicious TLD",  f"Yes ({domain.split('.')[-1]}) – often used in spam" if spam_tld else "Normal TLD",  "bad"  if spam_tld   else "ok"))
        checks.append(("🔢", "IP in URL",        "Yes – suspicious!" if ip_in_url else "No",                       "bad"  if ip_in_url   else "ok"))
        checks.append(("🏷️", "Brand Spoofing",  "Detected – fake brand name!" if brand_spoof else "None found",   "bad"  if brand_spoof else "ok"))
        checks.append(("📏", "Long Subdomain",   "Suspicious length" if long_sub else "Normal",                    "warn" if long_sub    else "ok"))
        checks.append(("➖", "Excess Dashes",    "Yes – common in spam" if excess_dash else "No",                  "warn" if excess_dash else "ok"))
        checks.append(("🔢", "Numeric Subdomain","Yes – suspicious" if num_sub else "No",                          "warn" if num_sub     else "ok"))
        checks.append(("📜", "URL Length",       f"{len(target)} chars – very long" if url_len_sus else f"{len(target)} chars – normal",  "warn" if url_len_sus else "ok"))
        checks.append(("📡", "DNS Resolves",     resolved_ip if resolved_ok else "❌ Cannot resolve – suspicious!", "ok"   if resolved_ok else "bad"))

        if spam_tld:     spam_score += 35
        if ip_in_url:    spam_score += 30
        if brand_spoof:  spam_score += 35
        if not is_https: spam_score += 10
        if long_sub:     spam_score += 10
        if excess_dash:  spam_score += 10
        if num_sub:      spam_score += 10
        if not resolved_ok: spam_score += 20
        if url_len_sus:  spam_score += 10
        if is_trusted:   spam_score = max(0, spam_score - 30)

    spam_score = min(100, spam_score)
    return checks, spam_score

def verdict(score):
    if score >= 65:
        return ("🚨 SPAM / DANGEROUS",   "red",    "This link looks dangerous. Do NOT click it.")
    elif score >= 35:
        return ("⚠️  SUSPICIOUS",        "yellow", "Be careful. This link has several red flags.")
    else:
        return ("✅  LOOKS SAFE",         "green",  "No major red flags detected.")

# ── Display ───────────────────────────────────────────────────────────────────
def print_banner():
    console.print()
    console.print(Text(BANNER, style="bold cyan"), justify="center")
    console.print(Align.center(Text("Anyone can use this! Just paste a link or IP below.", style="dim")))
    console.print()

def show_result(target, checks, score):
    label, color, summary = verdict(score)

    # Big verdict panel
    bar_full  = int(score / 5)
    bar_empty = 20 - bar_full
    bar       = "█" * bar_full + "░" * bar_empty

    verdict_text = Text()
    verdict_text.append(f"\n  {label}\n", style=f"bold {color}")
    verdict_text.append(f"  {summary}\n\n", style="white")
    verdict_text.append(f"  Spam Risk:  ", style="dim")
    verdict_text.append(f"{bar}", style=f"bold {color}")
    verdict_text.append(f"  {score}%\n", style=f"bold {color}")

    console.print(Panel(verdict_text, border_style=color, expand=True,
                        title=f"[bold]Result for: [cyan]{escape(target[:70])}{'...' if len(target)>70 else ''}[/cyan][/bold]"))
    console.print()

    # Checks table
    table = Table(box=box.ROUNDED, border_style="bright_black",
                  header_style="bold cyan", show_lines=True, expand=True,
                  title="🔍 Detailed Checks")
    table.add_column("",         width=4)
    table.add_column("Check",    style="bold white", min_width=18)
    table.add_column("Finding",  min_width=35)
    table.add_column("Status",   justify="center", width=10)

    status_map = {
        "ok":   ("[green]● SAFE[/green]",   "green"),
        "warn": ("[yellow]▲ WARN[/yellow]", "yellow"),
        "bad":  ("[red]✖ RISK[/red]",       "red"),
    }

    for icon, name, value, status in checks:
        label_str, col = status_map.get(status, ("ℹ INFO", "cyan"))
        table.add_row(icon, name, f"[{col}]{escape(str(value))}[/{col}]", label_str)

    console.print(table)
    console.print()

    # Tip box
    if score >= 35:
        tips = [
            "► Don't enter passwords or personal info on suspicious links",
            "► You can verify at [cyan underline]virustotal.com[/cyan underline] (free, paste the link there)",
            "► Forward suspicious emails to your IT/security team",
        ]
        if score >= 65:
            tips.insert(0, "[red bold]► Do NOT click this link! Block the sender.[/red bold]")
        tip_text = "\n".join(tips)
        console.print(Panel(tip_text, title="[yellow]💡 What to do[/yellow]", border_style="yellow", padding=(0, 2)))
        console.print()

# ── Main ─────────────────────────────────────────────────────────────────────
def main():
    print_banner()
    console.print(Rule("[bold cyan]Spam & Link Checker[/bold cyan]", style="cyan"))
    console.print("[dim]  Paste any link, URL, or IP address to check if it's spam.[/dim]")
    console.print("[dim]  Type [bold]exit[/bold] to quit. No account or API key needed!\n[/dim]")

    while True:
        try:
            target = Prompt.ask("\n[bold green]  🔗 Paste link or IP[/bold green]").strip()
        except (KeyboardInterrupt, EOFError):
            console.print("\n[bold cyan]  Stay safe online! 🛡[/bold cyan]\n")
            break

        if not target:
            console.print("[dim]  Please paste a link or IP address.[/dim]")
            continue
        if target.lower() in ("exit", "quit", "q"):
            console.print("\n[bold cyan]  Stay safe online! 🛡[/bold cyan]\n")
            break

        console.print()
        with Progress(SpinnerColumn(style="cyan"), TextColumn("[cyan]Checking...[/cyan]"), transient=True) as p:
            p.add_task("", total=None)
            time.sleep(0.6)
            checks, score = check_target(target)

        show_result(target, checks, score)
        console.print(Rule(style="bright_black"))

if __name__ == "__main__":
    main()
