# ─── Helpers ─────────────────────────────────────────────────────────────────

def is_ip(target: str) -> bool:
    pattern = r"^(\d{1,3}\.){3}\d{1,3}$"
    if not re.match(pattern, target.strip()):
        return False
    parts = target.strip().split(".")
    return all(0 <= int(p) <= 255 for p in parts)

def extract_domain(url: str) -> str:
    try:
        if not url.startswith(("http://", "https://")):
            url = "http://" + url
        return urllib.parse.urlparse(url).hostname or url
    except Exception:
        return url

def resolve_ip(domain: str) -> str:
    try:
        return socket.gethostbyname(domain)
    except Exception:
        return "Unresolvable"

def is_private_ip(parts):
    p = list(map(int, parts))
    if p[0] == 10: return True
    if p[0] == 172 and 16 <= p[1] <= 31: return True
    if p[0] == 192 and p[1] == 168: return True
    return False

# ─── Heuristic Analysis ──────────────────────────────────────────────────────

def analyze_ip(ip: str):
    parts = ip.strip().split(".")
    ints  = list(map(int, parts))
    flags = []

    private  = is_private_ip(parts)
    loopback = ints[0] == 127
    tor_like = ints[0] in TOR_FIRST_OCTETS
    multicast= ints[0] >= 224

    flags.append(("🌐", "Type",             "IPv4 Address",              "info"))
    flags.append(("🏠", "Private Range",    "Yes (RFC1918)" if private else "No (Public)", "warn" if private else "ok"))
    flags.append(("🔁", "Loopback",         "Yes" if loopback else "No",                  "warn" if loopback else "ok"))
    flags.append(("📡", "Multicast",        "Yes" if multicast else "No",                 "warn" if multicast else "ok"))
    flags.append(("🧅", "Tor / VPN Range",  "Possible" if tor_like else "Unlikely",       "bad"  if tor_like else "ok"))

    return flags

def analyze_url(url: str):
    lower  = url.lower()
    domain = extract_domain(lower)
    flags  = []

    is_https    = lower.startswith("https://")
    susp_tld    = any(domain.endswith(t) for t in SUSPICIOUS_TLDS)
    has_ip_dom  = bool(re.search(r"\d+\.\d+\.\d+\.\d+", domain))
    parts       = domain.split(".")
    long_sub    = any(len(p) > 30 for p in parts[:-2]) if len(parts) > 2 else False
    brand_spoof = any(b in lower for b in BRAND_KEYWORDS)
    excess_dash = lower.count("-") > 3
    num_sub     = any(p.isdigit() for p in parts[:-2])
    path_depth  = lower.count("/") > 5
    resolved_ip = resolve_ip(domain)
    resolved_ok = resolved_ip != "Unresolvable"

    flags.append(("🔒", "Protocol",         "HTTPS" if is_https else "HTTP (Insecure)",          "ok"  if is_https    else "warn"))
    flags.append(("📛", "TLD Risk",         "Suspicious TLD" if susp_tld else "Normal TLD",      "bad" if susp_tld    else "ok"))
    flags.append(("🔢", "IP in Domain",     "Detected" if has_ip_dom else "None",                "bad" if has_ip_dom  else "ok"))
    flags.append(("📏", "Long Subdomain",   "Detected" if long_sub else "Normal",                "warn"if long_sub    else "ok"))
    flags.append(("🏷️", "Brand Spoofing",  "Possible" if brand_spoof else "None Detected",      "bad" if brand_spoof else "ok"))
    flags.append(("➖", "Excess Dashes",    "Yes" if excess_dash else "No",                      "warn"if excess_dash else "ok"))
    flags.append(("🔢", "Numeric Subdomain","Yes" if num_sub else "No",                          "warn"if num_sub     else "ok"))
    flags.append(("🌿", "Deep URL Path",    "Yes (Obfuscation?)" if path_depth else "Normal",    "warn"if path_depth  else "ok"))
    flags.append(("📡", "DNS Resolution",   resolved_ip if resolved_ok else "Failed",            "ok"  if resolved_ok else "bad"))

    return flags

def compute_score(flags) -> int:
    score = 100
    for _, _, _, status in flags:
        if status == "bad":  score -= 25
        if status == "warn": score -= 10
    return max(0, min(100, score))

def score_meta(score: int):
    if score >= 70:
        return ("LIKELY SAFE",  "green",  "✅")
    elif score >= 40:
        return ("SUSPICIOUS",   "yellow", "⚠️")
    else:
        return ("HIGH RISK",    "red",    "🚨")

STATUS_COLORS = {"ok": "green", "warn": "yellow", "bad": "red", "info": "cyan"}

# ─── AI Analysis ─────────────────────────────────────────────────────────────

def get_ai_analysis(target: str, score: int, flags, target_type: str, api_key: str) -> str:
    flag_summary = "\n".join(f"{label}: {val} ({status})" for _, label, val, status in flags)
    label, _, _ = score_meta(score)
    prompt = f"""You are a cybersecurity expert analyzing a {target_type} for reputation and threats.

Target: {target}
Reputation Score: {score}/100
Verdict: {label}

Heuristic Analysis:
{flag_summary}

Give a concise threat analysis (4-6 sentences) covering:
1. Overall threat assessment
2. Specific risks or red flags detected
3. What type of attack this might indicate (if malicious)
4. Recommended action for a security analyst

Be direct, technical, and specific. No markdown formatting. Plain text only."""

    client = anthropic.Anthropic(api_key=api_key)
    message = client.messages.create(
        model="claude-sonnet-4-20250514",
        max_tokens=1000,
        messages=[{"role": "user", "content": prompt}]
    )
    return message.content[0].text

